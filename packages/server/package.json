{
  "name": "@deckos/server",
  "version": "0.4.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "pnpm --filter @deckos/contracts build && tsc",
    "typecheck": "pnpm --filter @deckos/contracts build && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "import-templates": "tsx scripts/import-casaos-templates.ts"
  },
  "dependencies": {
    "@deckos/contracts": "workspace:*",
    "@grpc/grpc-js": "1.14.4",
    "@hono/node-server": "^1.19.13",
    "@hono/trpc-server": "^0.4.2",
    "@trpc/server": "^11.9.0",
    "busboy": "^1.6.0",
    "dockerode": "^5.0.0",
    "fs-extra": "^11.3.3",
    "hono": "^4.12.26",
    "protobufjs": "7.6.3",
    "systeminformation": "^5.31.6",
    "yaml": "^2.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/dockerode": "^4.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.10",
    "@vitest/coverage-v8": "^3.2.6",
    "nodemon": "^3.1.11",
    "rimraf": "^6.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
