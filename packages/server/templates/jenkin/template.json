{
  "id": "jenkin",
  "title": "Jenkins CI/CD",
  "description": "Jenkins Continuous Integration and Delivery server.",
  "categories": ["Network"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8080",
      "required": true
    },
    {
      "key": "VOLUME_JENKINS__DATA",
      "label": "JENKINS /DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    },
    {
      "key": "VOLUME_JENKINS__VAR_JENKINS_HOME",
      "label": "JENKINS /VAR/JENKINS_HOME",
      "type": "path",
      "defaultValue": "./jenkins-home",
      "required": true
    }
  ]
}
