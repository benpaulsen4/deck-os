{
  "id": "jellyseerr",
  "title": "Jellyseerr",
  "description": "Jellyseerr is a free and open source software application for managing requests for your media library.",
  "categories": ["Media"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "5055",
      "required": true
    },
    {
      "key": "VOLUME_JELLYSEERR__APP_CONFIG",
      "label": "JELLYSEERR /APP/CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    }
  ]
}
