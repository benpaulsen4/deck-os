{
  "id": "downtify",
  "title": "Downtify",
  "description": "Download Spotify music with album art and metadata",
  "categories": ["Downloader"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8582",
      "required": true
    },
    {
      "key": "VOLUME_DOWNTIFY__DOWNLOADS",
      "label": "DOWNTIFY /DOWNLOADS",
      "type": "path",
      "defaultValue": "./downloads",
      "required": true
    }
  ]
}
