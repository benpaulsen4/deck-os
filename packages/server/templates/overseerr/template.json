{
  "id": "overseerr",
  "title": "Overseerr",
  "description": "Overseerr is a request management and media discovery tool built to work with your existing Plex ecosystem.",
  "categories": ["Media"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "5055",
      "required": true
    },
    {
      "key": "VOLUME_OVERSEERR__CONFIG",
      "label": "OVERSEERR /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    }
  ]
}
