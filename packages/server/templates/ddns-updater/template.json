{
  "id": "ddns-updater",
  "title": "ddns-updater",
  "description": "Simple and easy to use DDNS",
  "categories": ["Network"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8000",
      "required": true
    },
    {
      "key": "VOLUME_DDNS_UPDATER__UPDATER_DATA",
      "label": "DDNS-UPDATER /UPDATER/DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    }
  ]
}
