{
  "id": "ddns-go",
  "title": "ddns-go",
  "description": "Simple and easy to use DDNS",
  "categories": ["Network"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "9876",
      "required": true
    },
    {
      "key": "VOLUME_DDNS_GO__ROOT",
      "label": "DDNS-GO /ROOT",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    }
  ]
}
