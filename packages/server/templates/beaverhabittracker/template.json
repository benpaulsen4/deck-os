{
  "id": "beaverhabittracker",
  "title": "BeaverHabitTracker",
  "description": "A self-hosted, goal-free habit tracking tool.",
  "categories": ["Utilities"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "15580",
      "required": true
    },
    {
      "key": "VOLUME_BEAVERHABITTRACKER__APP__USER",
      "label": "BEAVERHABITTRACKER /APP/.USER",
      "type": "path",
      "defaultValue": "./",
      "required": true
    }
  ]
}
