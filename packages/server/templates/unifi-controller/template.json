{
  "id": "unifi-controller",
  "title": "Unifi-controller [legacy]",
  "description": "For Unifi to adopt other devices, e.g. an Access Point, it is required to change the inform IP address. Because Unifi runs inside Docker by default it uses an IP address not accessible by other devices. To change this go to Settings > System Settings > Controller Configuration and set the Controller Hostname/IP to a hostname or IP address accessible by your devices. Additionally the checkbox \"Override inform host with controller hostname/IP\" has to be checked, so that devices can connect to the controller during adoption (devices use the inform-endpoint during adoption).",
  "categories": ["Network"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "3478",
      "required": true
    },
    {
      "key": "PORT_UNIFI_CONTROLLER_10001",
      "label": "PORT UNIFI CONTROLLER 10001",
      "type": "port",
      "defaultValue": "10001",
      "required": false
    },
    {
      "key": "PORT_UNIFI_CONTROLLER_8080",
      "label": "PORT UNIFI CONTROLLER 8080",
      "type": "port",
      "defaultValue": "8383",
      "required": false
    },
    {
      "key": "PORT_UNIFI_CONTROLLER_8443",
      "label": "PORT UNIFI CONTROLLER 8443",
      "type": "port",
      "defaultValue": "8443",
      "required": false
    },
    {
      "key": "PORT_UNIFI_CONTROLLER_1900",
      "label": "PORT UNIFI CONTROLLER 1900",
      "type": "port",
      "defaultValue": "1900",
      "required": false
    },
    {
      "key": "PORT_UNIFI_CONTROLLER_8843",
      "label": "PORT UNIFI CONTROLLER 8843",
      "type": "port",
      "defaultValue": "8843",
      "required": false
    },
    {
      "key": "PORT_UNIFI_CONTROLLER_8880",
      "label": "PORT UNIFI CONTROLLER 8880",
      "type": "port",
      "defaultValue": "8880",
      "required": false
    },
    {
      "key": "PORT_UNIFI_CONTROLLER_6789",
      "label": "PORT UNIFI CONTROLLER 6789",
