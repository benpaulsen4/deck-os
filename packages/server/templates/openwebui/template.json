{
  "id": "openwebui",
  "title": "Open WebUI",
  "description": "User-friendly WebUI for LLMs (Formerly Ollama WebUI)",
  "categories": ["Chat"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "3050",
      "required": true
    },
    {
      "key": "VOLUME_OPEN_WEBUI_OLLAMA__APP_BACKEND_DATA",
      "label": "OPEN-WEBUI-OLLAMA /APP/BACKEND/DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    },
    {
      "key": "VOLUME_OPEN_WEBUI_OLLAMA__ROOT__OLLAMA",
      "label": "OPEN-WEBUI-OLLAMA /ROOT/.OLLAMA",
      "type": "path",
      "defaultValue": "./-ollama",
      "required": true
    }
  ]
}
