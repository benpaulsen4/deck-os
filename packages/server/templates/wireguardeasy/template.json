{
  "id": "wireguardeasy",
  "title": "WireGuard Easy",
  "description": "WEB UI to manage WireGuard VPN.",
  "categories": ["Network"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "51820",
      "required": true
    },
    {
      "key": "PORT_WG_EASY_51821",
      "label": "PORT WG EASY 51821",
      "type": "port",
      "defaultValue": "51821",
      "required": false
    },
    {
      "key": "VOLUME_WG_EASY__ETC_WIREGUARD",
      "label": "WG-EASY /ETC/WIREGUARD",
      "type": "path",
      "defaultValue": "./wireguard",
      "required": true
    }
  ]
}
