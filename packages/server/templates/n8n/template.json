{
  "id": "n8n",
  "title": "n8n",
  "description": "Free and source-available fair-code licensed workflow automation tool. Easily automate tasks across different services.",
  "categories": ["Utilities"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "5678",
      "required": true
    },
    {
      "key": "VOLUME_N8N__HOME_NODE__N8N",
      "label": "N8N /HOME/NODE/.N8N",
      "type": "path",
      "defaultValue": "./-n8n",
      "required": true
    }
  ]
}
