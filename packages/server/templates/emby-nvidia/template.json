{
  "id": "emby-nvidia",
  "title": "Emby(Nvidia GPU)",
  "description": "TAKE YOUR MEDIA ANYWHERE WITH EMBY",
  "categories": ["Media"],
  "icon": "https://cdn.jsdelivr.net/gh/IceWhaleTech/CasaOS-AppStore@main/Apps/Emby/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8096",
      "required": true
    },
    {
      "key": "PORT_EMBY_8920",
      "label": "PORT EMBY 8920",
      "type": "port",
      "defaultValue": "8920",
      "required": false
    },
    {
      "key": "VOLUME_EMBY__CONFIG",
      "label": "EMBY /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_EMBY__DATA_TVSHOWS",
      "label": "EMBY /DATA/TVSHOWS",
      "type": "path",
      "defaultValue": "./tvshows",
      "required": true
    },
    {
      "key": "VOLUME_EMBY__DATA_MOVIES",
      "label": "EMBY /DATA/MOVIES",
      "type": "path",
      "defaultValue": "./movies",
      "required": true
    }
  ]
}
