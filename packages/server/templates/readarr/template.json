{
  "id": "readarr",
  "title": "Readarr",
  "description": "Readarr is a ebook collection manager for Usenet and BitTorrent users. It can monitor multiple RSS feeds for new books from your favorite authors and will interface with clients and indexers to grab, sort, and rename them.",
  "categories": ["Media"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8787",
      "required": true
    },
    {
      "key": "VOLUME_READARR__CONFIG",
      "label": "READARR /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_READARR__BOOKS",
      "label": "READARR /BOOKS",
      "type": "path",
      "defaultValue": "./books",
      "required": true
    },
    {
      "key": "VOLUME_READARR__DOWNLOADS",
      "label": "READARR /DOWNLOADS",
      "type": "path",
      "defaultValue": "./downloads",
      "required": true
    }
  ]
}
