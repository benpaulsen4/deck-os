{
  "id": "adguardhome",
  "title": "AdGuard Home",
  "description": "AdGuard Home is a network-wide software for blocking ads and tracking. After you set it up, it'll cover all your home devices, and you won't need any client-side software for that. Learn more on our official Github repository.",
  "categories": ["Network"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "531",
      "required": true
    },
    {
      "key": "PORT_ADGUARD_HOME_53",
      "label": "PORT ADGUARD HOME 53",
      "type": "port",
      "defaultValue": "531",
      "required": false
    },
    {
      "key": "PORT_ADGUARD_HOME_3000",
      "label": "PORT ADGUARD HOME 3000",
      "type": "port",
      "defaultValue": "3001",
      "required": false
    },
    {
      "key": "PORT_ADGUARD_HOME_853",
      "label": "PORT ADGUARD HOME 853",
      "type": "port",
      "defaultValue": "853",
      "required": false
    },
    {
      "key": "PORT_ADGUARD_HOME_784",
      "label": "PORT ADGUARD HOME 784",
      "type": "port",
      "defaultValue": "784",
      "required": false
    },
    {
      "key": "VOLUME_ADGUARD_HOME__OPT_ADGUARDHOME_WORK",
      "label": "ADGUARD-HOME /OPT/ADGUARDHOME/WORK",
      "type": "path",
      "defaultValue": "./opt/adguardhome/work",
      "required": true
    },
    {
      "key": "VOLUME_ADGUARD_HOME__OPT_ADGUARDHOME_CONF",
      "label": "ADGUARD-HOME /OPT/ADGUARDHOME/CONF",
      "type": "path",
      "defaultValue": "./opt/adguardhome/conf",
      "required": true
    }
  ]
}
