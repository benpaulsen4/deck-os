{
  "id": "chatbotui",
  "title": "Chatbot UI",
  "description": "Open source chat UI for AI models",
  "categories": ["Chat"],
  "icon": "assets/icon.jpg",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "3080",
      "required": true
    }
  ]
}
