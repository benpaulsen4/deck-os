{
  "id": "pinchflat",
  "title": "Pinchflat",
  "description": "Your next YouTube media manager",
  "categories": ["Media"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8945",
      "required": true
    },
    {
      "key": "VOLUME_PINCHFLAT__CONFIG",
      "label": "PINCHFLAT /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_PINCHFLAT__DOWNLOADS",
      "label": "PINCHFLAT /DOWNLOADS",
      "type": "path",
      "defaultValue": "./downloads",
      "required": true
    }
  ]
}
