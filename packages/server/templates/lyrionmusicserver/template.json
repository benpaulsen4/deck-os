      "type": "port",
      "defaultValue": "3483",
      "required": false
    },
    {
      "key": "PORT_LYRIONMUSICSERVER_3483_2",
      "label": "PORT LYRIONMUSICSERVER 3483",
      "type": "port",
      "defaultValue": "3483",
