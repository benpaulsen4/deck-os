{
  "id": "esphome",
  "title": "ESPHome",
  "description": "Home Automation systems",
  "categories": ["Home Automation"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "6052",
      "required": true
    },
    {
      "key": "VOLUME_ESPHOME__CONFIG",
      "label": "ESPHOME /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    }
  ]
}
