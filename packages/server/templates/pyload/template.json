{
  "id": "pyload",
  "title": "PyLoad",
  "description": "Free Downloader Manager.",
  "categories": ["Downloader"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8000",
      "required": true
    },
    {
      "key": "PORT_PYLOAD_9666",
      "label": "PORT PYLOAD 9666",
      "type": "port",
      "defaultValue": "9666",
      "required": false
    },
    {
      "key": "VOLUME_PYLOAD__CONFIG",
      "label": "PYLOAD /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_PYLOAD__DOWNLOADS",
      "label": "PYLOAD /DOWNLOADS",
      "type": "path",
      "defaultValue": "./downloads",
      "required": true
    }
  ]
}
