{
  "id": "smokeping",
  "title": "Smokeping",
  "description": "keeps track of your network latency.",
  "categories": ["Network"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "10280",
      "required": true
    },
    {
      "key": "VOLUME_SMOKEPING__CONFIG",
      "label": "SMOKEPING /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_SMOKEPING__DATA",
      "label": "SMOKEPING /DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    }
  ]
}
