{
  "id": "netdata",
  "title": "Netdata",
  "description": "Real-time Performance Monitoring",
  "categories": ["Utilities"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "19999",
      "required": true
    },
    {
      "key": "VOLUME_NETDATA__ETC_NETDATA",
      "label": "NETDATA /ETC/NETDATA",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_NETDATA__VAR_LIB_NETDATA",
      "label": "NETDATA /VAR/LIB/NETDATA",
      "type": "path",
      "defaultValue": "./lib",
      "required": true
    },
    {
      "key": "VOLUME_NETDATA__VAR_CACHE_NETDATA",
      "label": "NETDATA /VAR/CACHE/NETDATA",
      "type": "path",
      "defaultValue": "./cache",
      "required": true
    }
  ]
}
