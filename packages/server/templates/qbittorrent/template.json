{
  "id": "qbittorrent",
  "title": "qBittorrent",
  "description": "The qBittorrent project aims to provide an open-source software alternative to µTorrent.",
  "categories": ["Downloader"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "8080",
      "required": true
    },
    {
      "key": "VOLUME_QBITTORRENT__CONFIG",
      "label": "QBITTORRENT /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_QBITTORRENT__DOWNLOADS",
      "label": "QBITTORRENT /DOWNLOADS",
      "type": "path",
      "defaultValue": "./downloads",
      "required": true
    }
  ]
}
