{
  "id": "lazylibrarian",
  "title": "Lazylibrarian",
  "description": "Lazylibrarian is a program to follow authors and grab metadata for all your digital reading needs. It uses a combination of Goodreads Librarything and optionally GoogleBooks as sources for author info and book info. This container is based on the DobyTang fork.",
  "categories": ["Downloader"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "5299",
      "required": true
    },
    {
      "key": "VOLUME_LAZYLIBRARIAN__DOWNLOADS",
      "label": "LAZYLIBRARIAN /DOWNLOADS",
      "type": "path",
      "defaultValue": "./downloads",
      "required": true
    },
    {
      "key": "VOLUME_LAZYLIBRARIAN__BOOKS",
      "label": "LAZYLIBRARIAN /BOOKS",
      "type": "path",
      "defaultValue": "./books",
      "required": true
    },
    {
      "key": "VOLUME_LAZYLIBRARIAN__CONFIG",
      "label": "LAZYLIBRARIAN /CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    }
  ]
}
