{
  "id": "alist",
  "title": "Alist",
  "description": "Mount your cloud drive on your home NAS",
  "categories": ["Cloud"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "5244",
      "required": true
    },
    {
      "key": "VOLUME_ALIST__OPT_ALIST_DATA",
      "label": "ALIST /OPT/ALIST/DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    }
  ]
}
