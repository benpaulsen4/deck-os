{
  "id": "kavita",
  "title": "Kavita",
  "description": "Kavita is a free and open source web based Comic and Book Server.",
  "categories": ["Media"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "5150",
      "required": true
    },
    {
      "key": "VOLUME_KAVITA__KAVITA_CONFIG",
      "label": "KAVITA /KAVITA/CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_KAVITA__MANGA",
      "label": "KAVITA /MANGA",
      "type": "path",
      "defaultValue": "./manga",
      "required": true
    }
  ]
}
