{
  "id": "myspeed",
  "title": "MySpeed",
  "description": "Analysis software that shows your internet speed for up to 30 days.",
  "categories": ["Utilities"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "5216",
      "required": true
    },
    {
      "key": "VOLUME_MYSPEED__MYSPEED_DATA",
      "label": "MYSPEED /MYSPEED/DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    }
  ]
}
