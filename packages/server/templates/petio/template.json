{
  "id": "petio",
  "title": "Petio",
  "description": "A third party companion app available to Plex server owners to allow their users to request, review and discover content.",
  "categories": ["Media"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "7777",
      "required": true
    },
    {
      "key": "VOLUME_PETIO__APP_API_CONFIG",
      "label": "PETIO /APP/API/CONFIG",
      "type": "path",
      "defaultValue": "./config",
      "required": true
    },
    {
      "key": "VOLUME_PETIO__APP_LOGS",
      "label": "PETIO /APP/LOGS",
      "type": "path",
      "defaultValue": "./logs",
      "required": true
    }
  ]
}
