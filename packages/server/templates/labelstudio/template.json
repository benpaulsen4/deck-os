{
  "id": "labelstudio",
  "title": "Label Studio",
  "description": "Label Studio is an open source data labeling tool. It lets you label data types like audio, text, images, videos, and time series with a simple and straightforward UI and export to various model formats. It can be used to prepare raw data or improve existing training data to get more accurate ML models.",
  "categories": ["AI"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "PGID",
      "label": "PGID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "PUID",
      "label": "PUID",
      "type": "number",
      "defaultValue": "1000",
      "required": false
    },
    {
      "key": "TZ",
      "label": "TZ",
      "type": "string",
      "defaultValue": "UTC",
      "required": false
    },
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "3080",
      "required": true
    },
    {
      "key": "VOLUME_LABEL_STUDIO__LABEL_STUDIO_DATA",
      "label": "LABEL-STUDIO /LABEL-STUDIO/DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    }
  ]
}
