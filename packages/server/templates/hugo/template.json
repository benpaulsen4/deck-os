{
  "id": "hugo",
  "title": "Hugo",
  "description": "The world's fastest framework for building websites",
  "categories": ["Developer"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "1313",
      "required": true
    },
    {
      "key": "VOLUME_HUGO__PROJECT",
      "label": "HUGO /PROJECT",
      "type": "path",
      "defaultValue": "./project",
      "required": true
    },
    {
      "key": "VOLUME_HUGO__CACHE",
      "label": "HUGO /CACHE",
      "type": "path",
      "defaultValue": "./cache",
      "required": true
    }
  ]
}
