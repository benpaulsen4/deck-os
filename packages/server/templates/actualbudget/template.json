{
  "id": "actualbudget",
  "title": "Actual Budget",
  "description": "Privacy-first finance app with envelope budgeting and multi-device sync.",
  "categories": ["Finance"],
  "icon": "assets/icon.png",
  "webUrlTemplate": "http://{{DECKOS_HOST}}:{{WEB_PORT}}",
  "parameters": [
    {
      "key": "WEB_PORT",
      "label": "WEB PORT",
      "type": "port",
      "defaultValue": "15006",
      "required": true
    },
    {
      "key": "VOLUME_ACTUALBUDGET__DATA",
      "label": "ACTUALBUDGET /DATA",
      "type": "path",
      "defaultValue": "./data",
      "required": true
    }
  ]
}
