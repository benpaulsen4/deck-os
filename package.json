{
  "name": "deckos",
  "version": "0.4.3",
  "private": true,
  "description": "Self-hosted homelab management platform",
  "scripts": {
    "dev": "concurrently --kill-others -n server,client -c green,cyan \"pnpm --filter @deckos/server dev\" \"wait-on --verbose --timeout 120000 tcp:3001 && pnpm --filter @deckos/client dev\"",
    "dev:simple": "pnpm --filter @deckos/server dev",
    "dev:nodelay": "concurrently -n client,server -c cyan,green \"pnpm --filter @deckos/client dev\" \"pnpm --filter @deckos/server dev\"",
    "build": "pnpm --filter @deckos/server build && pnpm --filter @deckos/client build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @deckos/server test && pnpm --filter @deckos/client test",
    "test:server": "pnpm --filter @deckos/server test",
    "test:client": "pnpm --filter @deckos/client test",
    "test:coverage": "pnpm --filter @deckos/server test:coverage && pnpm --filter @deckos/client test:coverage",
    "clean": "pnpm -r clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "release:cut": "node scripts/cut-release.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.1",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.5"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
